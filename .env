# Path to ChromeDriver (absolute path recommended)
CHROMEDRIVER_PATH=/usr/local/bin/chromedriver

# SQLite database file
DATABASE_PATH=scraped_data.db

# Concurrency limit for aiohttp
CONCURRENCY_LIMIT=10

# Selenium fallback for JS pages (true/false)
ENABLE_SELENIUM_FALLBACK=true

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# nlp model config

# Sentiment model (default: CardiffNLP multi-class)
MODEL_SENTIMENT=cardiffnlp/twitter-roberta-base-sentiment-latest

# optional features
ENABLE_KEYWORDS=true
ENABLE_TOPICS=true
ENABLE_SUMMARIZATION=true
ENABLE_EMOTIONS=true

# cache config

# Hours before a URL is re-scraped
CACHE_EXPIRY_HOURS=24

# FastAPI host and port
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit dashboard port
DASHBOARD_PORT=8501
